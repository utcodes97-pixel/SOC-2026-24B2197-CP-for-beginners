#include <bits/stdc++.h>
using namespace std;
const int N = 2e5 + 5;
int a[N];
int seg[4 * N];
void build(int idx, int left, int right)
{
    if (left == right)
    {
        seg[idx] = a[left];
        return;
    }
    int mid = (left + right) / 2;
    build(2 * idx + 1, left, mid);
    build(2 * idx + 2, mid + 1, right);
    seg[idx] = max(seg[2 * idx + 1], seg[2 * idx + 2]);
}
int query(int node, int l, int r, int ql, int qr)
{
    if (l > qr || r < ql)
    {
        return INT_MIN;
    }
    if (ql <= l && r <= qr)
    {
        return seg[node];
    }
    int mid = (l + r) / 2;
    return max(query(2 * node + 1, l, mid, ql, qr),
               query(2 * node + 2, mid + 1, r, ql, qr));
}
void update(int node, int l, int r, int idx, int val)
{
    if (l == r)
    {
        a[idx] = val;
        seg[node] = val;
        return;
    }
    int mid = (l + r) / 2;
    if (idx <= mid)
    {
        update(2 * node + 1, l, mid, idx, val);
    }
    else
    {
        update(2 * node + 2, mid + 1, r, idx, val);
    }
    seg[node] = max(seg[2 * node + 1], seg[2 * node + 2]);
}

int main()
{
    int n;
    cin >> n;

    for (int i = 0; i < n; i++)
        cin >> a[i];

    build(0, 0, n - 1);

    cout << query(0, 0, n - 1, 2, 5) << "\n";

    update(0, 0, n - 1, 3, 100);

    cout << query(0, 0, n - 1, 2, 5) << "\n";
}
