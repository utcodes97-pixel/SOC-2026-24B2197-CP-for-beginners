#include <bits/stdc++.h>
using namespace std;
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    int n,ans;cin>>n;
    vector<pair<int,int>>events;
    int a,b;
   
    for(int i=0;i<n;i++){
         cin>>a>>b;
      events.push_back({a,+1});
      events.push_back({b,-1});
    }
    sort(events.begin(),events.end());
    int cur=0;ans=0;
    for(auto x:events){
        cur+= x.second;
        ans=max(ans,cur);
    }
    
cout<<ans;
    return 0;
}
