#include <bits/stdc++.h>
using namespace std;

int solve(const string &s, int k, char target) {
    int l = 0, cnt = 0, ans = 0;

    for (int r = 0; r < (int)s.size(); r++) {
        if (s[r] != target) cnt++;

        while (cnt > k) {
            if (s[l] != target) cnt--;
            l++;
        }

        ans = max(ans, r - l + 1);
    }

    return ans;
}

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int n, k;
    cin >> n >> k;

    string s;
    cin >> s;

    cout << max(solve(s, k, 'a'), solve(s, k, 'b')) << '\n';

    return 0;
}
