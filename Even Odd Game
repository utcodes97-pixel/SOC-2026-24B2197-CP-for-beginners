#include <bits/stdc++.h>
using namespace std;
void solve(){
    int n;cin>>n;vector<long long>v(n);for(int i=0;i<n;i++){cin>>v[i];}
    sort(v.rbegin(),v.rend());
    long long ans=0;
    for(int i=0;i<n;i++){
        if(i%2==0){
                     if(v[i]%2==0){ans+=v[i];}
        }
        else{
                 if(v[i]%2==1){ans-=v[i];}
        }
    }
    if(ans>0){cout<<"Alice"<<"\n";}
    else if(ans<0){cout<<"Bob"<<"\n";}
    else{cout<<"Tie"<<"\n";}
}
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);int T;cin>>T;
    while(T--){
        solve();
    }
    
    return 0;
}
