#include <bits/stdc++.h>
using namespace std;
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    int n,m,k;
    cin>>n>>m>>k;
    vector<int> v(n,0);
    vector<int>a(m,0);
    for(int i=0;i<n;i++){
cin>>v[i];
    }
    for(int i=0;i<m;i++){
cin>>a[i];
    }
    sort(v.begin(),v.end());
    sort(a.begin(),a.end());
    int i=0,j=0;int ans=0;
    while(i<n && j<m){
         if(v[i]-k<=a[j] && v[i]+k>=a[j]){
            ans++;
            i++;j++;
        }
       else if(v[i]-k>a[j]){j++;}
        else {i++;}
    }
    cout<<ans;
    return 0;
}
