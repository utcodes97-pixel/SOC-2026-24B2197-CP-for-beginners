#include<bits/stdc++.h>
using namespace std;
using ll = long long;
using ld = long double;
const ll N = 1'000'000'000'000L;
unordered_set<ll>cubess;
vector<ll>vals;
void precalc(){
for(ll i=1;i*i*i<=N;i++){
    ll xx=i*i*i;
    cubess.insert(xx);
    vals.push_back(xx);
}
}
void solve(){
    ll n;cin>>n;
     for(ll x:vals){
        if(x>n){break;}
        else{if(cubess.count(n-x)){
                cout<<"YES\n";return;
        }}
     }
      cout<<"NO\n";return;
}
int main() {
    precalc();
int t; cin >> t;
while(t--){
      solve();
     
}

}
    
