#include <bits/stdc++.h>
using namespace std;
bool solve(int n,int m){
    if(n==m){return true;}
   else if(n<m || n%3!=0){return false;}
   else if(n%3==0){return solve(n/3,m) || solve((2*n)/3,m);}
}
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);int T;cin>>T;
    while(T--){
        int n,m;cin>>n>>m;
        if(solve(n,m)){cout<<"YES"<<"\n";}
        else{cout<<"NO"<<"\n";}
    }
    
    return 0;
}
