#include <bits/stdc++.h>
using namespace std;
long long MOD=1000000007;
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
   long long n;
    cin>>n;
   long long d[n+1];
    d[1]=0;
    d[2]=1;
    for(long long i=3;i<=n;i++)
    {
        d[i]=(((d[i-1]+d[i-2])%MOD)*(i-1))%MOD;
    }
    cout<<d[n];
        return 0;
}
 
