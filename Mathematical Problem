#include <bits/stdc++.h>
using namespace std;
void solve(){
    int n;cin>>n;string s;cin>>s;
    int ans=INT_MAX;
    for(int skip=0;skip<n-1;skip++){
        vector<int>a;
        for(int i=0;i<n;i++){
            if(i==skip){a.push_back(10*(s[i]-'0')+(s[i+1]-'0'));i++;}
           else{ a.push_back(s[i]-'0');}
        }
        bool isz=false;bool all1=true;
        int res=0;
        for(int i=0;i<n-1;i++){
           if(a[i]==0){isz=true;break;}
           if(a[i]!=1){all1=false;res+=a[i];}
        }
        if(isz){res=0;cout<<0<<"\n";return;}
        if(all1){res=1;}
        
        ans=min(ans,res);
    }
    cout<<ans<<"\n";
}
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);int T;cin>>T;
    while(T--){
        solve();
    }
    return 0;
}
