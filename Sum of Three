#include <bits/stdc++.h>

using namespace std;

int n;

inline void read() {
	cin >> n;
}

inline void solve() {
   if(n<7){puts("NO");return ;}
   int x,y,z;
	for(int i=1;i<=2;i++){
      for(int j=1;j<=5;j++){
         if(i==j){continue;}
         x=i;y=j;z=n-(x+y);
         if(z==x || z==y){continue;}
         if(z%3==0 || x%3==0 || y%3==0){continue;}
           puts("YES");
           cout << x << ' ' << y << ' ' << z << endl;
           return;
      }
   }
      puts("NO");
   
}

int main () {
    int t;
    cin >> t;
    while (t--){
        read();
        solve();
    }
}
