using namespace std;
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    int n,m;
    cin>>n>>m;int a;
    multiset<int>s;for(int i=0;i<n;i++){cin>>a;s.insert(a);}
    for(int i=0;i<m;i++){
        cin>>a;
        auto it=s.upper_bound(a);
        if(it==s.begin()){
            cout<<-1<<"\n";continue;
        }
       it--;
        cout<<*it<<"\n";
        s.erase(it);
    
    
}
