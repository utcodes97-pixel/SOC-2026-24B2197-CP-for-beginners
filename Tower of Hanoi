#include <bits/stdc++.h>
using namespace std;
void tofhanoi(int index,int f,int t,int a){
   if (index==0){return ;}
   if(index==1){cout<<f<<" "<<t<<"\n";}
   else{
    tofhanoi(index-1,f,a,t);
    cout<<f<<" "<<t<<"\n";
    tofhanoi(index-1,a,t,f);
 
   }
 
}
 
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
int n;cin>>n;
int hn=1;int chn=1;
for(int i=1;i<n;i++){
chn=2*hn +1;hn=chn;
}
cout<<chn<<"\n";
tofhanoi(n,1,3,2);                               
    return 0;
}
