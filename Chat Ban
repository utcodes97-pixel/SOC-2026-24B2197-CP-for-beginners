#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
void solve(){int k;ll x;cin>>k>>x;
    // if complete triangle possible
    if(1LL*k*k<=x){cout<<2*k-1<<"\n";}
    else if((((1LL*k)*(1LL*k+1))/2)>=x){
          ll l=1;ll r=k;// no of messages that we can print
          while(l<=r){
            ll mid=(l+r)/2;
            ll no=(mid*(mid+1))/2;
            if(no==x){l=mid;break;}
            if(no<x){l=mid+1;}
            else{r=mid-1;}
          }
          cout<<l<<"\n";
    }
    else{
        ll rem=x-(1LL*(1LL*k)*(1LL*k+1))/2;
        ll a1=1;ll a2=k-1;
        while(a1<=a2){
            ll mid=(a1+a2)/2;
            ll sum=(mid*(2*k-1-mid))/2;
            if(sum==rem){a1=mid;break;}
            if(sum<rem){a1=mid+1;}
            else{a2=mid-1;}
        }
        cout<<1LL*k+a1<<"\n";
    }
    
}
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);int T;cin>>T;
    while(T--){
        solve();
    }
    
    return 0;
}
