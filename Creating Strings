#include <bits/stdc++.h>
using namespace std;
set<string>st;
void solve(int idx,string& s){
    if(idx==s.size()){
        st.insert(s);return ;
    }
    else{
        for(int i=idx;i<s.size();i++){
            swap(s[i],s[idx]);
            solve(idx+1,s);
            swap(s[i],s[idx]);
 
        }
    }
 
}
int main()
{        
     ios::sync_with_stdio(false);
    cin.tie(nullptr);
 
    string s;
    cin>>s;
    solve(0,s);
 
     cout << st.size() << "\n";
 
    for(auto x : st) {
        cout << x << "\n";
    }
 
    return 0;
}
