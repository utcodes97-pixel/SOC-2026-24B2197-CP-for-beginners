#include <bits/stdc++.h>
using namespace std;
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    int n;cin>>n;
    vector<pair<int,int>>st;
    int a,b;
    for(int i=0;i<n;i++){
        cin>>a>>b;
        st.push_back({b,a});
    }
    int ans=0;
    int stime,etime;
    sort(st.begin(),st.end());
    int end=0;
for(auto x:st){
    stime=x.second;
    etime=x.first;
    if(stime>=end){
    ans++;
    end=etime;  }
 
 
}
cout<<ans;
 
    return 0;
}
