#include <bits/stdc++.h>
using namespace std;
int main()
{        
    int n;cin>>n;
    vector<long long>ve(n);
    long long total=0;
    for(int i=0;i<n;i++){
        cin>>ve[i];
        total+=ve[i];
    }        
    long long ans=LLONG_MAX;     
    for(int mask=1;mask<(1<<n);mask++){
        long long sum=0;
        for(int i=0;i<n;i++){
            if(mask &(1<<i)){sum+=ve[i];}
        }
        ans=min(ans,llabs(total-2*sum));
    }       
    cout<<ans<<"\n";
    return 0;
}
 
