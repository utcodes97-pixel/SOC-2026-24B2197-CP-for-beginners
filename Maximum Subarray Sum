#include <bits/stdc++.h>
using namespace std;
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    int n;cin>>n;
    long long maxi,cur;
    long long e;cin>>e;maxi=cur=e;
    for(int i=1;i<n;i++){
      cin>>e;if(cur+e<e){cur=e;maxi=max(maxi,cur);}
      else{cur=cur+e;maxi=max(maxi,cur);}
    }
    cout<<maxi;
    return 0;
}
