#include <bits/stdc++.h>
using namespace std;
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);int t;cin>>t;
    while(t--){
        int n;cin>>n;vector<pair<int,int>>v(n+1);
        for(int i=1;i<=n;i++){cin>>v[i].first;v[i].second=i;}
        sort(v.begin()+1,v.end());
        int nxt[n+1];long long sum[n+1];int ans[n+1];
        sum[0]=0;nxt[0]=0;
        for(int i=1;i<=n;i++){
            if(nxt[i-1]>=i){nxt[i]=nxt[i-1];sum[i]=sum[i-1];}
        else {
            sum[i]=sum[i-1]+v[i].first;
            nxt[i]=i;
            while(nxt[i]+1 <=n && sum[i]>=v[nxt[i]+1].first){
                nxt[i]++;
                sum[i]+=v[nxt[i]].first;
            }
        }
        ans[v[i].second]=nxt[i];

        }
        for(int i=1;i<=n;i++){cout<<ans[i]-1<<" ";}
        cout<<endl;
        
    }
}
