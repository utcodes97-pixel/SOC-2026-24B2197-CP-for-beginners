#include <bits/stdc++.h>
using namespace std;
void solve(){
    int n;cin>>n;
    vector<int>v(n);for(int i=0;i<n;i++){cin>>v[i];}
    int ans=0;
       for(int i=0;i<n;i++){
        for(int j=i+1;j<n;j++){
            ans=max(ans,v[i]^v[j]);
        }
       }cout<<ans<<"\n";
}
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);int T;cin>>T;
    while(T--){
        solve();
    }
    
    
    return 0;
}
