#include <bits/stdc++.h>
using namespace std;
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    int t;cin>>t;
    int n;
    while(t--){
        cin>>n;vector<int>v(n);for(int i=0;i<n;i++){cin>>v[i];}
        int f=v[0];int l=v[n-1];
        if(f==-1 && l!=-1){v[0]=l;}
        else if(f!=-1 && l==-1){v[n-1]=f;}
        cout<<abs(v[n-1]-v[0])<<"\n";
        for(int i=0;i<n;i++){
            cout<<max(0,v[i])<<" ";
        }
cout<<endl;
    }
    return 0;
}
