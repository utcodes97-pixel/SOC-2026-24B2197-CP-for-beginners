#include <bits/stdc++.h>
using namespace std;
vector<string> gycd(int n){
    if(n==1){return {"0","1"};}
    vector<string>prevgcd=gycd(n-1);
    vector<string>revpcd=prevgcd;
    reverse(revpcd.begin(),revpcd.end());
    int size=prevgcd.size();
    int index=0;
    while(index<size){
        string zeroappndd="1"+revpcd[index];
        prevgcd[index]="0"+prevgcd[index];
        prevgcd.push_back(zeroappndd);
        index++;
    }
    return prevgcd;
}
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    int n;cin>>n;
    vector<string>ans=gycd(n);
   for(long long int i=0;i<ans.size();i++){cout<<ans[i]<<"\n";}
    return 0;
}
