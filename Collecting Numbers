#include <bits/stdc++.h>
using namespace std;
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
 
    int n;cin>>n;
    vector<int>arr(n,0);
    vector<int>idc(n+1,0);
    for(int i=0;i<n;i++){cin>>arr[i];idc[arr[i]]=i;}
    int ans=1;
    for(int j=1;j<n;j++){
         if( idc[j]<idc[j+1]){continue;}
         ans++;
    }
cout<<ans;
 
    return 0;
}
