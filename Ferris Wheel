#include <bits/stdc++.h>
using namespace std;
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    int n,x;
    cin>>n>>x;
    vector<int>a(n,0);
    for(int i=0;i<n;i++){
        cin>>a[i];
    }
    sort(a.begin(),a.end());
    int l=0;int r=n-1;int ans=0;
    while(l<r){
    if(a[l]+a[r]>x){ans++;r--;}
    else if(a[l]+a[r]<=x){ans++;l++;r--;}
    }
    if(l==r){ans++;}
    cout<<ans;
    return 0;
}
