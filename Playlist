#include <bits/stdc++.h>
using namespace std;
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
int n;
cin>>n;
map<int,int>mp;
vector<int>v(n);for(int i=0;i<n;i++){cin>>v[i];}
int start=0;int end;int ans=0;
for(end=0;end<n;end++){
if(mp.find(v[end])==mp.end()){
    mp.insert({v[end],end});
}
else{
    if(mp[v[end]]>=start){start=mp[v[end]]+1;}
    mp[v[end]]=end;
}
 
ans=max(ans,end-start+1);
}
cout<<ans<<"\n";
    return 0;
}
