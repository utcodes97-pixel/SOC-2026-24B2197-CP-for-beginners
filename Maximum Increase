#include <bits/stdc++.h>
using namespace std;
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
    int n;cin>>n;vector<int>v(n);for(int i=0;i<n;i++){cin>>v[i];}
    int curr=1;int len=1;
    for(int i=1;i<n;i++){
if(v[i]>v[i-1]){curr++;}
else{len=max(len,curr);curr=1;}
    }
    len=max(len,curr);
    cout<<len<<"\n";
    return 0;
}
