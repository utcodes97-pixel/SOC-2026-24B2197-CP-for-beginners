#include <bits/stdc++.h>
using namespace std;
void solve(){long long n;cin>>n;
    long long v[n+1]={0},p[n+1]={0};
    int us[n+1]={0};
    for(int i=1;i<=n;i++){cin>>p[i];}
    string s;cin>>s;
    for(int i=1;i<=n;i++){
        if(us[i]){continue;}
        int sz=0;
        while(!us[i]){
            us[i]=1;
            sz+=s[i-1]=='0';
            i=p[i];
        }
        while(us[i]!=2){
            v[i]=sz;
            us[i]=2;
            i=p[i];
        }
    }
for(int i=1;i<=n;i++){cout<<v[i]<<" ";}cout<<endl;
    
}
int main()
{
    ios::sync_with_stdio(false);
    cin.tie(nullptr);int T;cin>>T;
    while(T--){
        solve();
    }
    
    return 0;
}
